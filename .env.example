# =============================================================================
# ENVIRONMENT CONFIGURATION
# Copy this file to .env.local and update values for your environment
# =============================================================================

# =============================================================================
# APPLICATION
# =============================================================================
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api
APP_PORT=3000

# =============================================================================
# DATABASE
# =============================================================================
# SQLite configuration
DATABASE_PATH=./data/app.db
DATABASE_BACKUP_PATH=./data/backups

# Optional: PostgreSQL or MySQL configuration
# DATABASE_URL=postgresql://user:password@localhost:5432/nextjs_app
# REDIS_URL=redis://localhost:6379

# =============================================================================
# AUTHENTICATION
# =============================================================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this
JWT_REFRESH_EXPIRATION=30d

# OAuth Providers (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Passkey/WebAuthn
PASSKEY_ORIGIN=http://localhost:3000
PASSKEY_RP_ID=localhost
PASSKEY_RP_NAME=My App

# =============================================================================
# FILE UPLOAD & STORAGE
# =============================================================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800  # 50MB in bytes
ALLOWED_FILE_TYPES=pdf,doc,docx,xls,xlsx,jpg,jpeg,png,gif,mp4,mov,avi

# S3 Configuration (optional)
# AWS_S3_BUCKET=my-bucket
# AWS_S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# =============================================================================
# VIDEO STREAMING
# =============================================================================
VIDEO_ENCRYPTION_KEY=your-video-encryption-key-min-32-chars
VIDEO_STORAGE_PATH=./public/videos
HLS_PLAYLIST_SIZE=10
HLS_TARGET_DURATION=4

# =============================================================================
# BACKEND SERVICES
# =============================================================================
# Express Backend
BACKEND_PORT=3001
BACKEND_URL=http://localhost:3001

# NestJS Backend (optional)
NESTJS_PORT=3002
NESTJS_URL=http://localhost:3002

# PHP Server (optional)
PHP_PORT=8000

# =============================================================================
# WEBSOCKET & REAL-TIME
# =============================================================================
SOCKET_IO_PORT=3000
SOCKET_IO_CORS_ORIGIN=http://localhost:3000
SOCKET_IO_CORS_CREDENTIALS=true

# =============================================================================
# SECURITY
# =============================================================================
# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# Session/Cookie
SESSION_SECRET=your-session-secret-key
COOKIE_SECURE=false  # Set to true in production with HTTPS
COOKIE_SAME_SITE=lax
COOKIE_MAX_AGE=86400000  # 24 hours in milliseconds

# =============================================================================
# EXTERNAL APIs
# =============================================================================
# Email Service (optional)
SENDGRID_API_KEY=
MAIL_FROM=noreply@yourapp.com

# Analytics (optional)
GOOGLE_ANALYTICS_ID=
MIXPANEL_TOKEN=

# =============================================================================
# LOGGING & MONITORING
# =============================================================================
LOG_LEVEL=info
LOG_FORMAT=json  # 'json' or 'text'
SENTRY_DSN=  # For error tracking
DATADOG_API_KEY=  # For monitoring

# =============================================================================
# DEVELOPMENT
# =============================================================================
DEBUG=nextjs:*
SKIP_ENV_VALIDATION=false  # Set to true to skip .env validation
MOCK_API_RESPONSES=false   # Enable mock responses in development
